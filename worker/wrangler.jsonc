{
  // Cloudflare Worker serving the JLCPCB catalog from D1.
  // Deploy: see worker/README.md (needs `wrangler login` + a D1 database).
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jlcpcb-parts-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "observability": { "enabled": true },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "jlcpcb-parts",
      "database_id": "570a2012-6e2e-4de4-a0ef-0974bebc21b4"
    }
  ]
}
